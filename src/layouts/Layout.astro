---
import { Font } from 'astro:assets';
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';
interface Props { title: string; description?: string; }
const { title, description = 'Christopher Brothers LLC — concrete installation, pavers, and retaining walls in the South Hills of Pittsburgh. Family-owned since 1955. Call 412-884-2933.' } = Astro.props;
const currentPath = Astro.url.pathname;
const canonicalUrl = new URL(currentPath, Astro.site).href;
const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/services', label: 'Services' },
  { href: '/contact', label: 'Contact' },
];
---
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Christopher Brothers LLC" />
    <Font cssVariable="--font-display" preload />
    <Font cssVariable="--font-body" preload />
    <ClientRouter />
  </head>
  <body>
    <a href="#main-content" class="skip-to-content">Skip to content</a>
    <header class="site-header" id="site-header">
      <div class="header-inner">
        <a href="/" class="logo" aria-label="Christopher Brothers home">Christopher<span class="logo-accent"> Brothers</span></a>
        <nav class="main-nav" aria-label="Main navigation">
          {navLinks.map(link => (<a href={link.href} class:list={['nav-link', { active: currentPath === link.href }]} aria-current={currentPath === link.href ? 'page' : undefined}>{link.label}</a>))}
          <a href="tel:412-884-2933" class="btn btn--maroon header-cta">412-884-2933</a>
        </nav>
        <button class="menu-toggle" id="menu-toggle" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-nav">
          <span class="menu-bar" aria-hidden="true"></span><span class="menu-bar" aria-hidden="true"></span><span class="menu-bar" aria-hidden="true"></span>
        </button>
      </div>
    </header>
    <div class="mobile-nav" id="mobile-nav" aria-hidden="true">
      <nav aria-label="Mobile navigation">
        {navLinks.map(link => (<a href={link.href} class:list={['mobile-link', { active: currentPath === link.href }]} aria-current={currentPath === link.href ? 'page' : undefined}>{link.label}</a>))}
        <a href="tel:412-884-2933" class="btn btn--maroon mobile-cta">Call 412-884-2933</a>
      </nav>
    </div>
    <main id="main-content"><slot /></main>
    <footer class="site-footer">
      <div class="footer-inner container--wide">
        <div class="footer-brand">
          <span class="footer-name">Christopher Brothers LLC</span>
          <p>Concrete specialists since 1955.</p>
          <address>South Park, PA 15129</address>
        </div>
        <div class="footer-col">
          <h3>Contact</h3>
          <p><a href="tel:412-884-2933">412-884-2933</a></p>
          <p><a href="mailto:ed@christopherbros.com">ed@christopherbros.com</a></p>
        </div>
        <div class="footer-col">
          <h3>Services</h3>
          <a href="/services">Concrete</a>
          <a href="/services">Pavers</a>
          <a href="/services">Retaining Walls</a>
        </div>
        <div class="footer-col">
          <h3>Follow</h3>
          <a href="https://www.facebook.com/christopherbrosconcrete" target="_blank" rel="noopener noreferrer">Facebook</a>
          <a href="https://search.google.com/local/writereview?placeid=ChIJxdTElWv7NIgRQHM9VBXvuvs" target="_blank" rel="noopener noreferrer">Leave a Review</a>
        </div>
      </div>
      <div class="footer-bottom"><div class="container--wide"><p>&copy; {new Date().getFullYear()} Christopher Brothers LLC</p></div></div>
    </footer>
    <script>
      function initNav() {
        const toggle = document.getElementById('menu-toggle'); const nav = document.getElementById('mobile-nav'); const hdr = document.getElementById('site-header');
        if (!toggle || !nav) return;
        toggle.addEventListener('click', () => { const o = toggle.getAttribute('aria-expanded') === 'true'; toggle.setAttribute('aria-expanded', String(!o)); nav.setAttribute('aria-hidden', String(o)); toggle.classList.toggle('open'); nav.classList.toggle('open'); document.body.style.overflow = o ? '' : 'hidden'; });
        nav.querySelectorAll('a').forEach(l => l.addEventListener('click', () => { toggle.setAttribute('aria-expanded','false'); nav.setAttribute('aria-hidden','true'); toggle.classList.remove('open'); nav.classList.remove('open'); document.body.style.overflow=''; }));
        window.addEventListener('scroll', () => hdr.classList.toggle('scrolled', scrollY > 60), { passive: true });
      }
      function initReveal() {
        if (matchMedia('(prefers-reduced-motion: reduce)').matches) return;
        const obs = new IntersectionObserver(es => es.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); obs.unobserve(e.target); } }), { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });
        document.querySelectorAll('.reveal').forEach(el => { el.style.opacity='0'; el.style.transform='translateY(24px)'; el.style.transition='opacity .7s ease, transform .7s ease'; obs.observe(el); });
      }
      document.addEventListener('astro:page-load', () => { initNav(); initReveal(); });
    </script>
    <style>
      .skip-to-content { position: absolute; top: -100%; left: 50%; transform: translateX(-50%); background: var(--maroon); color: var(--white); padding: .75em 1.5em; z-index: 200; font-weight: 700; }
      .skip-to-content:focus { top: .5rem; }
      .site-header { position: sticky; top: 0; z-index: 100; background: color-mix(in oklch, var(--stone) 95%, transparent); backdrop-filter: blur(10px); border-bottom: 1px solid oklch(0 0 0 / .06); }
      .site-header.scrolled { box-shadow: 0 1px 10px oklch(0 0 0 / .06); }
      .header-inner { display: flex; align-items: center; justify-content: space-between; padding: var(--space-sm) var(--gutter); max-width: 1300px; margin: 0 auto; }
      .logo { font-family: var(--font-display); font-size: 1.25rem; font-weight: 900; color: var(--slate); text-transform: uppercase; letter-spacing: .02em; }
      .logo-accent { color: var(--maroon); }
      .main-nav { display: none; align-items: center; gap: var(--space-md); }
      .nav-link { font-family: var(--font-display); font-size: .8125rem; font-weight: 700; letter-spacing: .06em; text-transform: uppercase; color: var(--text-light); }
      .nav-link:hover, .nav-link.active { color: var(--slate); }
      .nav-link.active { border-bottom: 2px solid var(--maroon); padding-bottom: 2px; }
      .header-cta { font-size: .75rem; padding: .6em 1.2em; }
      @media (min-width: 800px) { .main-nav { display: flex; } .menu-toggle { display: none; } }
      .menu-toggle { display: flex; flex-direction: column; gap: 5px; background: none; border: none; cursor: pointer; padding: 10px; min-width: 44px; min-height: 44px; align-items: center; justify-content: center; }
      .menu-bar { display: block; width: 22px; height: 2px; background: var(--slate); transform-origin: center; }
      .menu-toggle.open .menu-bar:nth-child(1) { transform: translateY(7px) rotate(45deg); }
      .menu-toggle.open .menu-bar:nth-child(2) { visibility: hidden; }
      .menu-toggle.open .menu-bar:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }
      .mobile-nav { position: fixed; inset: 0; z-index: 99; background: var(--stone); display: none; flex-direction: column; align-items: center; justify-content: center; }
      .mobile-nav.open { display: flex; }
      .mobile-nav nav { display: flex; flex-direction: column; align-items: center; gap: var(--space-lg); }
      .mobile-link { font-family: var(--font-display); font-size: 2rem; font-weight: 900; color: var(--slate); text-transform: uppercase; }
      .mobile-link:hover, .mobile-link.active { color: var(--maroon); }
      .mobile-cta { margin-top: var(--space-md); }
      .site-footer { background: var(--slate); color: oklch(.85 .005 70); padding-top: var(--space-2xl); }
      .footer-inner { display: grid; grid-template-columns: 1fr; gap: var(--space-xl); padding-bottom: var(--space-xl); }
      @media (min-width: 700px) { .footer-inner { grid-template-columns: repeat(2, 1fr); } }
      @media (min-width: 1000px) { .footer-inner { grid-template-columns: 1.5fr 1fr 1fr 1fr; } }
      .footer-name { font-family: var(--font-display); font-weight: 900; font-size: 1.125rem; text-transform: uppercase; display: block; margin-bottom: .25em; }
      .footer-inner address { font-style: normal; font-size: .9375rem; opacity: .7; }
      .footer-inner p { font-size: .9375rem; opacity: .8; }
      .footer-col h3 { font-family: var(--font-display); font-size: .6875rem; font-weight: 700; letter-spacing: .15em; text-transform: uppercase; color: var(--maroon-light); margin-bottom: var(--space-sm); }
      .footer-col a { display: flex; align-items: center; font-size: .875rem; min-height: 44px; opacity: .8; }
      .footer-col a:hover { opacity: 1; color: var(--white); }
      .footer-bottom { border-top: 1px solid oklch(1 0 0 / .08); padding: var(--space-md) 0; text-align: center; font-size: .75rem; opacity: .5; }
    </style>
  </body>
</html>
