---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import concretePour from '../assets/images/concrete-pour.jpg';
import badge from '../assets/images/70-years-badge.jpeg';
---

<Layout
  title="About Us | Christopher Brothers LLC | Since 1955"
  description="Christopher Brothers LLC has served the South Hills of Pittsburgh since 1955. Three generations of genuine craftsmanship in concrete, pavers, and retaining walls."
  canonicalPath="/about/"
>

  <!-- PAGE HERO -->
  <section class="page-hero" aria-label="About Christopher Brothers">
    <div class="page-hero-bg">
      <Image
        src={concretePour}
        alt="Concrete work in progress"
        width={1920}
        height={600}
        loading="eager"
        class="page-hero-img"
      />
    </div>
    <div class="container page-hero-content">
      <p class="page-label">About Us</p>
      <h1>Since 1955.</h1>
    </div>
  </section>

  <!-- STORY -->
  <section class="story-section" aria-labelledby="story-heading">
    <div class="container">
      <div class="story-grid">
        <div class="story-text reveal">
          <h2 id="story-heading">Three generations. One standard.</h2>
          <p>
            Christopher Brothers LLC has served the community since 1955, providing
            70 years of experience across the South Hills region of Pittsburgh.
          </p>
          <p>
            Residential and commercial clients alike count on our family-owned company
            to provide the very best in concrete and retaining wall work. We know what
            it takes to complete the job and give you a surface that will last for
            generations.
          </p>
          <p>
            Companies and families choose us for their exterior renovation projects,
            which include driveways, patios, retaining walls, porches, pavers, and
            other living areas. Choose our team today for the very best in customer
            service and craftsmanship.
          </p>
        </div>
        <div class="story-badge reveal">
          <Image
            src={badge}
            alt="Christopher Brothers — 70 Years of Genuine Craftsmanship, 1955-2025"
            width={400}
            height={400}
            class="badge-img"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- TIMELINE -->
  <section class="timeline-section" aria-labelledby="timeline-heading">
    <div class="container">
      <h2 id="timeline-heading" class="sr-only">Our History</h2>
      <div class="timeline">
        <div class="timeline-item reveal">
          <div class="timeline-marker" aria-hidden="true">
            <span class="timeline-year">1955</span>
          </div>
          <div class="timeline-content">
            <h3>Founded</h3>
            <p>Christopher Brothers LLC was established, beginning a legacy of concrete and stone work in the South Hills of Pittsburgh.</p>
          </div>
        </div>

        <div class="timeline-item reveal">
          <div class="timeline-marker" aria-hidden="true">
            <span class="timeline-year">1970s</span>
          </div>
          <div class="timeline-content">
            <h3>Expanding across the South Hills</h3>
            <p>The company grew to serve over 30 communities in the greater Pittsburgh region, earning a reputation for reliable work.</p>
          </div>
        </div>

        <div class="timeline-item reveal">
          <div class="timeline-marker" aria-hidden="true">
            <span class="timeline-year">1990s</span>
          </div>
          <div class="timeline-content">
            <h3>Next generation</h3>
            <p>The second generation stepped in to carry the family tradition, adding pavers and expanded retaining wall services.</p>
          </div>
        </div>

        <div class="timeline-item reveal">
          <div class="timeline-marker" aria-hidden="true">
            <span class="timeline-year">Today</span>
          </div>
          <div class="timeline-content">
            <h3>70 years of genuine craftsmanship</h3>
            <p>Three generations later, Christopher Brothers continues to set the standard for concrete and retaining wall work across the South Hills.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- MISSION -->
  <section class="mission-block" aria-labelledby="mission-heading">
    <div class="container">
      <div class="mission-card reveal">
        <p class="section-label">Our Mission</p>
        <blockquote>
          <p id="mission-heading">
            To produce the best possible product and service, adding positive value for
            our customers while creating a safe and rewarding career for our employees.
          </p>
        </blockquote>
      </div>
    </div>
  </section>

  <!-- SERVICE AREA -->
  <section class="area-section" aria-labelledby="area-heading">
    <div class="container">
      <div class="area-grid">
        <div class="area-text reveal">
          <p class="section-label">Service Area</p>
          <h2 id="area-heading">The South Hills of Pittsburgh</h2>
          <p>We serve the following communities and surrounding areas:</p>
          <div class="area-communities">
            <ul>
              <li>Baldwin</li>
              <li>Bethel Park</li>
              <li>Brentwood</li>
              <li>Bridgeville</li>
              <li>Canonsburg</li>
              <li>Carnegie</li>
              <li>Carrick</li>
              <li>Castle Shannon</li>
              <li>Clairton</li>
              <li>Dormont</li>
            </ul>
            <ul>
              <li>Elizabeth</li>
              <li>Finleyville</li>
              <li>Greentree</li>
              <li>Jefferson Hills</li>
              <li>Monongahela</li>
              <li>Mt. Lebanon</li>
              <li>Mt. Oliver</li>
              <li>Peters Township</li>
              <li>Pleasant Hills</li>
              <li>South Park</li>
            </ul>
            <ul>
              <li>Union Township</li>
              <li>Upper St. Clair</li>
              <li>Washington</li>
              <li>West Mifflin</li>
              <li>Whitehall</li>
              <li>White Oak</li>
              <li>McMurray</li>
              <li>Venetia</li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section" aria-labelledby="cta-heading">
    <div class="container">
      <div class="cta-box reveal">
        <h2 id="cta-heading">Work with a team that's been here since 1955.</h2>
        <p>Get a free estimate on your next concrete, paver, or retaining wall project.</p>
        <div class="cta-actions">
          <a href="/contact/" class="btn btn-primary btn-lg">Get a Free Estimate</a>
          <a href="tel:+14128842933" class="btn btn-ghost btn-lg">Call 412-884-2933</a>
        </div>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* Page hero */
  .page-hero {
    position: relative;
    padding-block: var(--space-3xl) var(--space-2xl);
    overflow: hidden;
    min-height: 340px;
    display: flex;
    align-items: flex-end;
  }

  .page-hero-bg {
    position: absolute;
    inset: 0;
  }

  .page-hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.2;
    filter: saturate(0.2) contrast(1.1);
  }

  .page-hero-content {
    position: relative;
    z-index: 2;
  }

  .page-label {
    font-family: var(--font-mono), monospace;
    font-size: var(--text-xs);
    color: var(--red-500);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: var(--space-sm);
  }

  .page-hero h1 {
    font-size: var(--text-4xl);
  }

  /* Story */
  .story-section {
    padding-block: var(--space-3xl);
  }

  .story-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
    align-items: center;
  }

  @media (min-width: 768px) {
    .story-grid {
      grid-template-columns: 1.5fr 1fr;
      gap: var(--space-2xl);
    }
  }

  .story-text h2 {
    font-size: var(--text-3xl);
    margin-bottom: var(--space-lg);
  }

  .story-text p {
    color: var(--color-text-muted);
    line-height: 1.8;
    margin-bottom: var(--space-md);
  }

  .story-badge {
    display: flex;
    justify-content: center;
  }

  .badge-img {
    max-width: 280px;
    filter: invert(1) brightness(0.85);
    opacity: 0.7;
  }

  /* Timeline */
  .timeline-section {
    padding-block: var(--space-2xl) var(--space-3xl);
    background: var(--concrete-900);
  }

  .timeline {
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
    max-width: 700px;
    margin-inline: auto;
    padding-left: 2rem;
    border-left: 2px solid var(--color-border);
  }

  .timeline-item {
    position: relative;
    padding-left: var(--space-lg);
  }

  .timeline-marker {
    position: absolute;
    left: calc(-2rem - 1px);
    top: 0;
    transform: translateX(-50%);
  }

  .timeline-year {
    display: inline-block;
    font-family: var(--font-mono), monospace;
    font-size: var(--text-xs);
    font-weight: 700;
    color: var(--red-500);
    background: var(--concrete-900);
    padding: 0.2rem 0.6rem;
    letter-spacing: 0.05em;
  }

  .timeline-content h3 {
    font-size: var(--text-lg);
    margin-bottom: var(--space-xs);
  }

  .timeline-content p {
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    line-height: 1.7;
  }

  /* Mission */
  .mission-block {
    padding-block: var(--space-2xl);
  }

  .mission-card {
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border-subtle);
    padding: var(--space-2xl);
    max-width: 700px;
    margin-inline: auto;
  }

  .section-label {
    font-family: var(--font-mono), monospace;
    font-size: var(--text-xs);
    color: var(--red-500);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: var(--space-md);
  }

  .mission-card blockquote p {
    font-family: var(--font-display), Georgia, serif;
    font-size: var(--text-xl);
    font-style: italic;
    line-height: 1.5;
    color: var(--color-text);
    max-width: none;
  }

  /* Service area */
  .area-section {
    padding-block: var(--space-2xl) var(--space-3xl);
  }

  .area-text h2 {
    font-size: var(--text-2xl);
    margin-bottom: var(--space-md);
  }

  .area-text > p {
    color: var(--color-text-muted);
    margin-bottom: var(--space-lg);
  }

  .area-communities {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
  }

  @media (min-width: 480px) {
    .area-communities {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 768px) {
    .area-communities {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .area-communities ul {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .area-communities li {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    padding-left: 1rem;
    position: relative;
  }

  .area-communities li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.55em;
    width: 4px;
    height: 4px;
    background: var(--concrete-600);
  }

  /* CTA */
  .cta-section {
    padding-block: 0 var(--space-3xl);
  }

  .cta-box {
    background: var(--concrete-900);
    border: 1px solid var(--color-border-subtle);
    padding: var(--space-2xl);
    text-align: center;
  }

  .cta-box h2 {
    font-size: var(--text-2xl);
    margin-bottom: var(--space-md);
    max-width: 20ch;
    margin-inline: auto;
  }

  .cta-box > p {
    color: var(--color-text-muted);
    font-size: var(--text-lg);
    margin-inline: auto;
    margin-bottom: var(--space-xl);
  }

  .cta-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-md);
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-body), system-ui, sans-serif;
    font-size: var(--text-sm);
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 0.85rem 1.8rem;
    min-height: 48px;
    transition: all var(--duration-fast) var(--ease-out);
    cursor: pointer;
    border: none;
  }

  .btn-primary {
    background: var(--color-accent);
    color: white;
  }

  .btn-primary:hover {
    background: var(--color-accent-hover);
    transform: translateY(-1px);
  }

  .btn-ghost {
    background: transparent;
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
  }

  .btn-ghost:hover {
    border-color: var(--color-text-muted);
    color: var(--color-text);
  }

  .btn-lg {
    padding: 1rem 2.2rem;
    font-size: var(--text-base);
  }
</style>
