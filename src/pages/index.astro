---
/*
  DESIGN CONCEPT: "Poured in Place"

  Inspired by Oaks Brothers' dark palette layered photography approach, and
  brutalist architecture sites that use massive type as structural elements.
  The founding year 1955 becomes the hero — so large it fills the viewport,
  acting as a mask for the concrete pour photography. This mirrors the
  permanence of their work: concrete is poured once and lasts generations.

  The red from their logo appears sparingly — only on CTAs and the "CB"
  monogram — keeping the palette grounded in concrete grays and deep
  charcoal. Typography mixes DM Serif Display (authoritative, classic) with
  Inter (clean, modern body) to bridge the 70-year history with today.

  Reference sites: Oaks Brothers (dark overlay photography, layered surfaces),
  Layton Construction (trust metrics, portfolio grid), brutalist architecture
  sites (massive type-as-structure, raw material palettes).
*/

import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import concretePour from '../assets/images/concrete-pour.jpg';
import retainingWall from '../assets/images/retaining-wall.jpg';
import patio from '../assets/images/patio.jpg';
import badge from '../assets/images/70-years-badge.jpeg';
---

<Layout
  title="Christopher Brothers LLC | Concrete & Stone Experts | South Hills Pittsburgh"
  description="Christopher Brothers has served the South Hills of Pittsburgh since 1955. Concrete, pavers, and retaining walls — 70 years of genuine craftsmanship."
  canonicalPath="/"
>

  <!-- Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "GeneralContractor",
    "name": "Christopher Brothers LLC",
    "url": "https://christopher-brothers.keithkelly.dev",
    "telephone": "412-884-2933",
    "email": "ed@christopherbros.com",
    "foundingDate": "1955",
    "description": "Concrete, pavers, and retaining wall experts serving the South Hills of Pittsburgh since 1955.",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "South Park",
      "addressRegion": "PA",
      "postalCode": "15129",
      "addressCountry": "US"
    },
    "areaServed": {
      "@type": "GeoCircle",
      "geoMidpoint": {
        "@type": "GeoCoordinates",
        "latitude": 40.3179586,
        "longitude": -79.9793146
      },
      "geoRadius": "30000"
    },
    "sameAs": [
      "https://www.facebook.com/christopherbrosconcrete"
    ]
  })} />

  <!-- HERO: The signature moment — 1955 as architecture -->
  <section class="hero" aria-label="Introduction">
    <div class="hero-bg">
      <Image
        src={concretePour}
        alt="Workers pouring and smoothing concrete on a job site"
        width={1920}
        height={1280}
        loading="eager"
        class="hero-bg-img"
      />
    </div>
    <div class="hero-content">
      <div class="hero-year" aria-hidden="true">
        <span class="hero-year-text">1955</span>
      </div>
      <div class="hero-info container">
        <p class="hero-since">Since 1955</p>
        <h1 class="hero-headline">Concrete & Stone Experts</h1>
        <p class="hero-sub">Serving the South Hills of Pittsburgh for 70 years.</p>
        <div class="hero-actions">
          <a href="/contact/" class="btn btn-primary">Get a Free Estimate</a>
          <a href="tel:+14128842933" class="btn btn-ghost">412-884-2933</a>
        </div>
      </div>
    </div>
  </section>

  <!-- TRUST STRIP -->
  <section class="trust-strip" aria-label="Quick facts">
    <div class="container">
      <div class="trust-grid">
        <div class="trust-item reveal">
          <span class="trust-number" data-count="70">0</span>
          <span class="trust-label">Years in business</span>
        </div>
        <div class="trust-divider" aria-hidden="true"></div>
        <div class="trust-item reveal">
          <span class="trust-number" data-count="3">0</span>
          <span class="trust-label">Generations</span>
        </div>
        <div class="trust-divider" aria-hidden="true"></div>
        <div class="trust-item reveal">
          <span class="trust-number">30+</span>
          <span class="trust-label">Communities served</span>
        </div>
        <div class="trust-divider" aria-hidden="true"></div>
        <div class="trust-item reveal">
          <span class="trust-number">1955</span>
          <span class="trust-label">Family-owned since</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ABOUT PREVIEW -->
  <section class="about-preview" aria-labelledby="about-heading">
    <div class="container">
      <div class="about-grid">
        <div class="about-text reveal">
          <p class="section-label">About Us</p>
          <h2 id="about-heading">A surface that lasts for generations.</h2>
          <p class="about-body">
            Christopher Brothers LLC has served the community since 1955. Residential
            and commercial clients count on our family-owned company to provide the
            very best in concrete and retaining wall work across the South Hills
            region of Pittsburgh.
          </p>
          <p class="about-body">
            We know what it takes to complete the job and give you a result that holds
            up. Driveways, patios, retaining walls, porches, pavers. Choose our team for
            the best in customer service and craftsmanship.
          </p>
          <a href="/about/" class="link-arrow">Our story <span aria-hidden="true">&rarr;</span></a>
        </div>
        <div class="about-image reveal">
          <Image
            src={badge}
            alt="Christopher Brothers — 70 Years of Genuine Craftsmanship, 1955-2025"
            width={400}
            height={400}
            class="badge-img"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section class="services-section" aria-labelledby="services-heading">
    <div class="container">
      <p class="section-label reveal">What We Do</p>
      <h2 id="services-heading" class="services-title reveal">Three specialties. Seven decades of getting them right.</h2>

      <div class="services-grid">
        <a href="/services/" class="service-card reveal">
          <div class="service-card-img">
            <Image
              src={concretePour}
              alt="Workers smoothing freshly poured concrete"
              width={600}
              height={400}
              loading="lazy"
            />
          </div>
          <div class="service-card-body">
            <h3>Concrete</h3>
            <p>
              Driveways, walks, steps, patios, porches, garage floors,
              basement floors, footers, handicap ramps. Residential
              and commercial.
            </p>
            <span class="service-link" aria-hidden="true">Learn more &rarr;</span>
          </div>
        </a>

        <a href="/services/#pavers" class="service-card reveal">
          <div class="service-card-img">
            <Image
              src={patio}
              alt="Clean concrete patio with raised garden beds"
              width={600}
              height={400}
              loading="lazy"
            />
          </div>
          <div class="service-card-body">
            <h3>Pavers</h3>
            <p>
              We transform your project from beginning to end using the
              pavers of your choice. Bring your vision to life with a
              team that has done it thousands of times.
            </p>
            <span class="service-link" aria-hidden="true">Learn more &rarr;</span>
          </div>
        </a>

        <a href="/services/#retaining-walls" class="service-card reveal">
          <div class="service-card-img">
            <Image
              src={retainingWall}
              alt="Stone retaining wall with landscaping"
              width={600}
              height={400}
              loading="lazy"
            />
          </div>
          <div class="service-card-body">
            <h3>Retaining Walls</h3>
            <p>
              Versa-Lok, Unilock, Bauer, stone veneers, stone laid in
              mortar, stone drystack. We install the retaining wall you
              want, built to last.
            </p>
            <span class="service-link" aria-hidden="true">Learn more &rarr;</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- MISSION -->
  <section class="mission-section" aria-labelledby="mission-heading">
    <div class="mission-bg" aria-hidden="true">
      <Image
        src={retainingWall}
        alt="Retaining wall background"
        width={1920}
        height={600}
        loading="lazy"
        class="mission-bg-img"
      />
    </div>
    <div class="container mission-content">
      <blockquote class="reveal">
        <p id="mission-heading">
          Our mission is to produce the best possible product and service,
          adding positive value for our customers while creating a safe
          and rewarding career for our employees.
        </p>
        <footer>
          <cite>Christopher Brothers LLC</cite>
        </footer>
      </blockquote>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section" aria-labelledby="cta-heading">
    <div class="container">
      <div class="cta-box reveal">
        <h2 id="cta-heading">Ready to start your project?</h2>
        <p>Get a free estimate from our team. We serve the entire South Hills region.</p>
        <div class="cta-actions">
          <a href="/contact/" class="btn btn-primary btn-lg">Get a Free Estimate</a>
          <a href="tel:+14128842933" class="btn btn-ghost btn-lg">Call 412-884-2933</a>
        </div>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* ============================================
     HERO
     ============================================ */
  .hero {
    position: relative;
    min-height: 100dvh;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
    background: var(--concrete-950);
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  .hero-bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
    opacity: 0.35;
    filter: saturate(0.3) contrast(1.1);
  }

  .hero-content {
    position: relative;
    z-index: 2;
    width: 100%;
    padding-bottom: var(--space-2xl);
  }

  /* The massive year — the signature moment */
  .hero-year {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -55%);
    pointer-events: none;
    user-select: none;
  }

  .hero-year-text {
    font-family: var(--font-display), Georgia, serif;
    font-size: var(--text-hero);
    font-size: clamp(8rem, 5rem + 20vw, 28rem);
    line-height: 0.85;
    color: oklch(0.15 0.005 40);
    letter-spacing: -0.04em;
    white-space: nowrap;
    opacity: 0.6;
  }

  .hero-info {
    position: relative;
    z-index: 3;
  }

  .hero-since {
    font-family: var(--font-mono), monospace;
    font-size: var(--text-xs);
    color: var(--red-500);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: var(--space-sm);
  }

  .hero-headline {
    font-size: var(--text-4xl);
    color: var(--color-text);
    margin-bottom: var(--space-md);
    max-width: 12ch;
  }

  .hero-sub {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    margin-bottom: var(--space-lg);
    max-width: 40ch;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
  }

  /* ============================================
     BUTTONS
     ============================================ */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-body), system-ui, sans-serif;
    font-size: var(--text-sm);
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 0.85rem 1.8rem;
