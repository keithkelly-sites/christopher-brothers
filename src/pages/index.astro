    border-color: var(--concrete-600);
  }

  .service-card-img {
    aspect-ratio: 3 / 2;
    overflow: hidden;
  }

  .service-card-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: saturate(0.7) brightness(0.9);
    transition: transform var(--duration-slow) var(--ease-out),
                filter var(--duration-normal) var(--ease-out);
  }

  .service-card:hover .service-card-img img {
    transform: scale(1.05);
    filter: saturate(0.9) brightness(1);
  }

  .service-card-body {
    padding: var(--space-lg);
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .service-card-body h3 {
    font-size: var(--text-xl);
    margin-bottom: var(--space-sm);
  }

  .service-card-body p {
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    line-height: 1.7;
    flex: 1;
  }

  .service-link {
    display: inline-block;
    margin-top: var(--space-md);
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--red-500);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  /* ============================================
     MISSION
     ============================================ */
  .mission-section {
    position: relative;
    padding-block: var(--space-3xl);
    overflow: hidden;
  }

  .mission-bg {
    position: absolute;
    inset: 0;
  }

  .mission-bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.12;
    filter: saturate(0) contrast(1.2);
  }

  .mission-content {
    position: relative;
    z-index: 2;
    text-align: center;
    display: flex;
    justify-content: center;
  }

  .mission-content blockquote {
    max-width: 700px;
  }

  .mission-content blockquote p {
    font-family: var(--font-display), Georgia, serif;
    font-size: var(--text-2xl);
    font-style: italic;
    line-height: 1.4;
    color: var(--color-text);
    max-width: none;
    text-wrap: balance;
    margin-bottom: var(--space-lg);
  }

  .mission-content cite {
    font-family: var(--font-mono), monospace;
    font-size: var(--text-xs);
    font-style: normal;
    color: var(--color-text-dim);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  /* ============================================
     CTA
     ============================================ */
  .cta-section {
    padding-block: var(--space-2xl) var(--space-3xl);
  }

  .cta-box {
    background: var(--concrete-900);
    border: 1px solid var(--color-border-subtle);
    padding: var(--space-2xl);
    text-align: center;
  }

  .cta-box h2 {
    font-size: var(--text-3xl);
    margin-bottom: var(--space-md);
  }

  .cta-box > p {
    color: var(--color-text-muted);
    font-size: var(--text-lg);
    margin-inline: auto;
    margin-bottom: var(--space-xl);
  }

  .cta-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-md);
  }
</style>

<script>
  // Animated counters for trust strip
  function initCounters() {
    const counters = document.querySelectorAll('[data-count]');
    if (!counters.length) return;

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            const el = entry.target as HTMLElement;
            const target = parseInt(el.dataset.count || '0');
            animateCount(el, target);
            observer.unobserve(el);
          }
        });
      },
      { threshold: 0.5 }
    );

    counters.forEach(c => observer.observe(c));
  }

  function animateCount(el: HTMLElement, target: number) {
    const duration = 1500;
    const start = performance.now();

    function tick(now: number) {
      const elapsed = now - start;
      const progress = Math.min(elapsed / duration, 1);
      // Ease out cubic
      const eased = 1 - Math.pow(1 - progress, 3);
      const current = Math.round(eased * target);
      el.textContent = String(current);
      if (progress < 1) requestAnimationFrame(tick);
    }

    requestAnimationFrame(tick);
  }

  // Hero parallax — subtle depth on the year
  function initParallax() {
    const yearEl = document.querySelector('.hero-year-text') as HTMLElement;
    if (!yearEl) return;

    window.addEventListener('scroll', () => {
      const scrolled = window.scrollY;
      const rate = scrolled * 0.15;
      yearEl.style.transform = `translateY(${rate}px)`;
    }, { passive: true });
  }

  function init() {
    initCounters();
    initParallax();
  }

  // astro:page-load fires on initial load AND after every view transition
  document.addEventListener('astro:page-load', init);
</script>
