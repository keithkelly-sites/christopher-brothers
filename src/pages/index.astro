  }

  /* ============================================
     SERVICES
     ============================================ */
  .services-section {
    padding-block: var(--space-2xl) var(--space-3xl);
    background: var(--concrete-900);
  }

  .services-title {
    font-size: var(--text-2xl);
    color: var(--color-text);
    margin-bottom: var(--space-xl);
    max-width: 25ch;
  }

  .services-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
  }

  @media (min-width: 640px) {
