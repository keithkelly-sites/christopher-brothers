---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import concretePour from '../assets/images/concrete-pour.jpg';
import retainingWall from '../assets/images/retaining-wall.jpg';
import patio from '../assets/images/patio.jpg';
---

<Layout
  title="Services | Christopher Brothers LLC | Concrete, Pavers & Retaining Walls"
  description="Residential and commercial concrete, pavers, and retaining walls in the South Hills of Pittsburgh. Free estimates from Christopher Brothers LLC."
  canonicalPath="/services/"
>

  <!-- PAGE HERO -->
  <section class="page-hero" aria-label="Services overview">
    <div class="page-hero-bg">
      <Image
        src={concretePour}
        alt="Concrete work in progress"
        width={1920}
        height={600}
        loading="eager"
        class="page-hero-img"
      />
    </div>
    <div class="container page-hero-content">
      <p class="page-label">Our Services</p>
      <h1>Built to last. Every time.</h1>
    </div>
  </section>

  <!-- CONCRETE -->
  <section class="service-detail" id="concrete" aria-labelledby="concrete-heading">
    <div class="container">
      <div class="detail-grid">
        <div class="detail-image reveal">
          <Image
            src={concretePour}
            alt="Workers smoothing freshly poured concrete on a residential project"
            width={700}
            height={500}
            loading="lazy"
          />
        </div>
        <div class="detail-text reveal">
          <p class="section-label">01</p>
          <h2 id="concrete-heading">Concrete</h2>
          <p class="detail-intro">
            Our team provides experienced concrete service for residential and
            commercial customers. Following strict engineering guidelines, we
            complete every project to the highest standard. Our customers are
            always satisfied with the quality and durability of our work.
          </p>

          <div class="detail-lists">
            <div class="detail-list">
              <h3>Residential</h3>
              <ul>
                <li>Driveways</li>
                <li>Walks</li>
                <li>Steps</li>
                <li>Patios</li>
                <li>Porches</li>
                <li>Garage Floors</li>
                <li>Basement Floors</li>
                <li>Footers</li>
                <li>Handicap Ramps</li>
              </ul>
            </div>
            <div class="detail-list">
              <h3>Commercial</h3>
              <ul>
                <li>Loading Docks</li>
                <li>Floors</li>
                <li>Footers</li>
                <li>Grade Beams</li>
                <li>Parking Pads</li>
                <li>Dumpster Pads</li>
                <li>Public Walkways &amp; Steps</li>
                <li>Handicap Ramps</li>
                <li>Raised Decks</li>
              </ul>
            </div>
          </div>

          <a href="/contact/" class="btn btn-primary">Get a Free Estimate</a>
        </div>
      </div>
    </div>
  </section>

  <!-- DIVIDER -->
  <div class="section-divider container" aria-hidden="true"><hr /></div>

  <!-- PAVERS -->
  <section class="service-detail service-detail--reversed" id="pavers" aria-labelledby="pavers-heading">
    <div class="container">
      <div class="detail-grid">
        <div class="detail-image reveal">
          <Image
            src={patio}
            alt="Clean paver patio with raised garden beds and outdoor furniture"
            width={700}
            height={500}
            loading="lazy"
          />
        </div>
        <div class="detail-text reveal">
          <p class="section-label">02</p>
          <h2 id="pavers-heading">Pavers</h2>
          <p class="detail-intro">
            Our team provides paver services to meet your needs. We transform
            your project from beginning to end using the pavers of your choice.
            Schedule your free estimate today to bring your vision to life.
          </p>

          <div class="detail-features">
            <div class="feature">
              <h3>Your Choice of Material</h3>
              <p>We work with every major paver brand and style to match your vision and budget.</p>
            </div>
            <div class="feature">
              <h3>Full-Service Installation</h3>
              <p>From site prep to final sealing, we handle the entire project so you don't have to.</p>
            </div>
          </div>

          <a href="/contact/" class="btn btn-primary">Get a Free Estimate</a>
        </div>
      </div>
    </div>
  </section>

  <!-- DIVIDER -->
  <div class="section-divider container" aria-hidden="true"><hr /></div>

  <!-- RETAINING WALLS -->
  <section class="service-detail" id="retaining-walls" aria-labelledby="walls-heading">
    <div class="container">
      <div class="detail-grid">
        <div class="detail-image reveal">
          <Image
            src={retainingWall}
            alt="Gray stone retaining wall with lush landscaping above"
            width={700}
            height={500}
            loading="lazy"
          />
        </div>
        <div class="detail-text reveal">
          <p class="section-label">03</p>
          <h2 id="walls-heading">Retaining Walls</h2>
          <p class="detail-intro">
            We install the retaining wall of your dreams. Using the material of
            your choice, we create a high-quality and long-lasting wall.
            Schedule your free estimate today.
          </p>

          <div class="detail-materials">
            <h3>Materials We Work With</h3>
            <ul class="material-tags">
              <li>Versa-Lok</li>
              <li>Unilock</li>
              <li>Bauer</li>
              <li>Stone Veneers</li>
              <li>Stone Laid in Mortar</li>
              <li>Stone Drystack</li>
            </ul>
          </div>

          <a href="/contact/" class="btn btn-primary">Get a Free Estimate</a>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-section" aria-labelledby="cta-heading">
    <div class="container">
      <div class="cta-box reveal">
        <h2 id="cta-heading">Start your project today.</h2>
        <p>Call us or fill out the form for a free estimate. We'll get back to you quickly.</p>
        <div class="cta-actions">
          <a href="/contact/" class="btn btn-primary btn-lg">Get a Free Estimate</a>
          <a href="tel:+14128842933" class="btn btn-ghost btn-lg">Call 412-884-2933</a>
        </div>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* ============================================
     PAGE HERO
     ============================================ */
  .page-hero {
    position: relative;
    padding-block: var(--space-3xl) var(--space-2xl);
    overflow: hidden;
    min-height: 340px;
    display: flex;
    align-items: flex-end;
  }

  .page-hero-bg {
    position: absolute;
    inset: 0;
  }

  .page-hero-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.2;
    filter: saturate(0.2) contrast(1.1);
  }

  .page-hero-content {
    position: relative;
    z-index: 2;
  }

  .page-label {
    font-family: var(--font-mono), monospace;
    font-size: var(--text-xs);
    color: var(--red-500);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: var(--space-sm);
  }

  .page-hero h1 {
    font-size: var(--text-4xl);
    max-width: 14ch;
  }

  /* ============================================
     SERVICE DETAIL SECTIONS
     ============================================ */
  .service-detail {
    padding-block: var(--space-2xl);
  }

  .detail-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-xl);
    align-items: start;
  }

  @media (min-width: 768px) {
    .detail-grid {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-2xl);
    }

    .service-detail--reversed .detail-grid {
      direction: rtl;
    }

    .service-detail--reversed .detail-grid > * {
      direction: ltr;
    }
  }

  .detail-image img {
    width: 100%;
    height: auto;
    aspect-ratio: 7 / 5;
    object-fit: cover;
    filter: saturate(0.7) brightness(0.9);
  }

  .section-label {
    font-family: var(--font-mono), monospace;
    font-size: var(--text-xs);
    color: var(--red-500);
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: var(--space-sm);
  }

  .detail-text h2 {
    font-size: var(--text-3xl);
    margin-bottom: var(--space-md);
  }

  .detail-intro {
    color: var(--color-text-muted);
    font-size: var(--text-base);
    line-height: 1.75;
    margin-bottom: var(--space-xl);
  }

  /* Service lists */
  .detail-lists {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-lg);
    margin-bottom: var(--space-xl);
  }

  .detail-list h3 {
    font-family: var(--font-body), system-ui, sans-serif;
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-dim);
    margin-bottom: var(--space-md);
  }

  .detail-list ul {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .detail-list li {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    padding-left: 1rem;
    position: relative;
  }

  .detail-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.55em;
    width: 4px;
    height: 4px;
    background: var(--red-500);
  }

  /* Features */
  .detail-features {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
    margin-bottom: var(--space-xl);
  }

  .feature h3 {
    font-family: var(--font-body), system-ui, sans-serif;
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-text);
    margin-bottom: var(--space-xs);
  }

  .feature p {
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    line-height: 1.7;
  }

  /* Material tags */
  .detail-materials {
    margin-bottom: var(--space-xl);
  }

  .detail-materials h3 {
    font-family: var(--font-body), system-ui, sans-serif;
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-text-dim);
    margin-bottom: var(--space-md);
  }

  .material-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .material-tags li {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    padding: 0.4rem 1rem;
    border: 1px solid var(--color-border);
    background: var(--color-bg-elevated);
  }

  /* Divider */
  .section-divider hr {
    border: none;
    border-top: 1px solid var(--color-border-subtle);
  }

  /* Buttons */
  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-body), system-ui, sans-serif;
    font-size: var(--text-sm);
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 0.85rem 1.8rem;
    min-height: 48px;
    transition: all var(--duration-fast) var(--ease-out);
    cursor: pointer;
    border: none;
  }

  .btn-primary {
    background: var(--color-accent);
    color: white;
  }

  .btn-primary:hover {
    background: var(--color-accent-hover);
    transform: translateY(-1px);
  }

  .btn-ghost {
    background: transparent;
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
  }

  .btn-ghost:hover {
    border-color: var(--color-text-muted);
    color: var(--color-text);
  }

  .btn-lg {
    padding: 1rem 2.2rem;
    font-size: var(--text-base);
  }

  /* CTA */
  .cta-section {
    padding-block: var(--space-2xl) var(--space-3xl);
  }

  .cta-box {
    background: var(--concrete-900);
    border: 1px solid var(--color-border-subtle);
    padding: var(--space-2xl);
    text-align: center;
  }

  .cta-box h2 {
    font-size: var(--text-3xl);
    margin-bottom: var(--space-md);
  }

  .cta-box > p {
    color: var(--color-text-muted);
    font-size: var(--text-lg);
    margin-inline: auto;
    margin-bottom: var(--space-xl);
  }

  .cta-actions {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-md);
  }
</style>
